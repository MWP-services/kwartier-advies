{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "noEmit": false,
    "outDir": ".worker-build",
    "rootDir": ".",
    "jsx": "react-jsx",
    "incremental": false,
    "types": ["node"],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "worker/**/*.ts",
    "lib/**/*.ts",
    "src/lib/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    ".worker-build",
    "tests"
  ]
}
